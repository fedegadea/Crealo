{
  "rewrites": [
    { "source": "/",        "destination": "/app.html" },
    { "source": "/landing", "destination": "/app.html" },
    { "source": "/login",   "destination": "/app.html" },
    { "source": "/app",     "destination": "/app.html" }
  ],
  "headers": [
    {
      "source": "/app.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
